# CMakeLists.txt 模板 - Knighter 风格的插件构建
#
# 用于构建 Clang Static Analyzer 插件
# 参考 Knighter 的 create_plugin.py

cmake_minimum_required(VERSION 3.13.4)

# 设置 LLVM 版本和路径
set(LLVM_VERSION "21")
set(LLVM_INCLUDE_DIR "/usr/lib/llvm-${LLVM_VERSION}/include")
set(LLVM_LIB_DIR "/usr/lib/llvm-${LLVM_VERSION}/lib")

# 查找 LLVM 包
find_package(LLVM REQUIRED CONFIG)

# 包含 LLVM 头文件
include_directories(${LLVM_INCLUDE_DIRS})
include_directories(${LLVM_INCLUDE_DIR})

# 添加 LLVM 定义
add_definitions(${LLVM_DEFINITIONS})

# 设置 C++ 标准
set(CMAKE_CXX_STANDARD 14)
set(CMAKE_CXX_STANDARD_REQUIRED ON)

# 包含 Clang 头文件
include_directories(
    ${LLVM_INCLUDE_DIR}/clang
)

# 设置输出目录
set(CMAKE_LIBRARY_OUTPUT_DIRECTORY ${CMAKE_BINARY_DIR}/lib)
set(CMAKE_RUNTIME_OUTPUT_DIRECTORY ${CMAKE_BINARY_DIR}/bin)

# 宏定义：添加插件
macro(add_clang_plugin plugin_name)
    # 插件源文件
    set(PLUGIN_SOURCE ${plugin_name}.cpp)

    # 导出符号文件
    set(EXPORTS_FILE ${plugin_name}.exports)

    # 检查 exports 文件是否存在
    if(EXISTS ${CMAKE_CURRENT_SOURCE_DIR}/${EXPORTS_FILE})
        set(LLVM_EXPORTED_SYMBOL_FILE ${CMAKE_CURRENT_SOURCE_DIR}/${EXPORTS_FILE})
    else()
        # 默认导出符号
        set(LLVM_EXPORTED_SYMBOL_FILE ${CMAKE_CURRENT_SOURCE_DIR}/default.exports)
        if(NOT EXISTS ${LLVM_EXPORTED_SYMBOL_FILE})
            file(WRITE ${LLVM_EXPORTED_SYMBOL_FILE} "clang_registerCheckers\nclang_analyzerAPIVersionString\n")
        endif()
    endif()

    # 创建模块库
    add_llvm_library(${plugin_name} MODULE ${PLUGIN_SOURCE})

    # 链接 Clang 库
    clang_target_link_libraries(${plugin_name} PRIVATE
        clangStaticAnalyzerCore
        clangStaticAnalyzerFrontend
        clangAnalysis
        clangAST
        clangBasic
        clangLex
    )

    # 设置插件属性
    set_target_properties(${plugin_name} PROPERTIES
        PREFIX ""
        OUTPUT_NAME ${plugin_name}
    )

    # 安装目标
    install(TARGETS ${plugin_name}
        LIBRARY DESTINATION lib
        RUNTIME DESTINATION bin
    )
endmacro()

# 默认导出符号文件
file(WRITE ${CMAKE_CURRENT_SOURCE_DIR}/default.exports
"clang_registerCheckers
clang_analyzerAPIVersionString
")

