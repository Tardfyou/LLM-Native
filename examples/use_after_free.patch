diff --git a/drivers/net/ethernet/realtek/rtl8139.c b/drivers/net/ethernet/realtek/rtl8139.c
index abc123..def456 100644
--- a/drivers/net/ethernet/realtek/rtl8139.c
+++ b/drivers/net/ethernet/realtek/rtl8139.c
@@ -542,8 +542,12 @@ static int rtl8139_open(struct net_device *dev)
 {
 	struct rtl8139_private *tp = netdev_priv(dev);
 	void __iomem *ioaddr = tp->mmio_addr;
-	unsigned char *tx_buffer = kmalloc(2048, GFP_KERNEL);
+	unsigned char *tx_buffer;
 	int retval;

+	tx_buffer = kmalloc(2048, GFP_KERNEL);
+	if (!tx_buffer)
+		return -ENOMEM;
+
 	/* Enable TX/RX */
 	writel(readl(ioaddr + ChipCmd) | CmdRxEnb | CmdTxEnb, ioaddr + ChipCmd);

@@ -561,6 +565,8 @@ static int rtl8139_open(struct net_device *dev)
 	if (retval) {
 		free_irq(dev->irq, dev);
 		netif_carrier_off(dev);
+		kfree(tx_buffer);
+		tx_buffer = NULL;
 		return retval;
 	}

@@ -572,6 +578,7 @@ static int rtl8139_close(struct net_device *dev)
 	struct rtl8139_private *tp = netdev_priv(dev);
 	void __iomem *ioaddr = tp->mmio_addr;

+	kfree(tp->tx_buffer);
+	tp->tx_buffer = NULL;
 	netif_stop_queue(dev);

 	/* Disable TX/RX */
